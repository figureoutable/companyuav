# Companies House API key — get one at https://developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=your-api-key-here

# Optional: delay in ms between officer API calls (default 200). Helps stay under 600 req/5 min.
# OFFICER_FETCH_DELAY_MS=200

# Daily fetch script (npm run daily-fetch): cap companies per run, default 2000
# MAX_COMPANIES_PER_SEARCH=2000

# Google Drive upload (optional): folder ID and path to service account JSON
# GOOGLE_DRIVE_FOLDER_ID=your-folder-id
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/google-service-account.json

# Email after daily-fetch — easiest: Resend (paste API key only)
# RESEND_API_KEY=re_xxxxxxxx
# DAILY_FETCH_EMAIL_TO=you@example.com
# RESEND_FROM="Company Scout <onboarding@resend.dev>"
# Or after verifying tryfigures.com: RESEND_FROM="Company Scout <reports@tryfigures.com>"
# After you verify a domain in Resend, use e.g. RESEND_FROM=reports@yourdomain.com

# Or SMTP (Gmail App Password, etc.)
# DAILY_FETCH_EMAIL_TO=you@example.com
# DAILY_FETCH_EMAIL_FROM=you@example.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_SECURE=false
